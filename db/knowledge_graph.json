  "evidence_standards": {
    "现场检查笔录": {
      "requirement": "2名以上执法人员，当事人签字确认",
      "content": ["检查时间地点", "被检查单位信息", "现场情况描述", "发现的问题", "采样取证情况", "当事人意见"],
      "tips": "客观描述，不使用主观判断词"
    },
    "询问笔录": {
      "requirement": "2名执法人员询问，被询问人逐页签字",
      "content": ["被询问人身份信息", "告知权利义务", "违法事实确认", "原因及经过", "整改态度"],
      "tips": "先问客观事实，再问主观认识"
    },
    "采样监测报告": {
      "requirement": "CMA资质检测机构出具",
      "content": ["采样点位", "采样时间", "检测项目", "检测结果", "标准限值", "达标判断"],
      "tips": "采样需执法人员和当事人共同在场确认"
    },
    "电子证据": {
      "requirement": "确保数据完整性和可追溯性",
      "content": ["在线监测数据", "用电量记录", "生产台账", "监控视频", "操作日志"],
      "tips": "电子证据易灭失，需优先固定保存"
    }
  },

  "criminal_thresholds": {
    "污染环境罪": {
      "law": "刑法第338条",
      "threshold": "严重污染环境",
      "criteria": [
        "在饮用水水源一级保护区排放有毒物质",
        "非法排放、倾倒、处置危废3吨以上",
        "排放含重金属超标3倍以上",
        "私设暗管排放有毒物质",
        "两年内因违反环保规定受过两次以上行政处罚又实施"
      ],
      "penalty": "3年以下有期徒刑，后果特别严重的3-7年"
    }
  }
